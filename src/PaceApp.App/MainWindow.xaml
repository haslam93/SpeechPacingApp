<Window x:Class="PaceApp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="392"
        Height="860"
        MinWidth="360"
        MinHeight="700"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}"
        ShowInTaskbar="True"
        Icon="Assets/PaceCoach.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#0F766E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource QuietButtonBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource QuietButtonBorder}" />
            <Setter Property="Foreground" Value="{DynamicResource QuietButtonFg}" />
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>
    </Window.Resources>

    <Border Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="🏃 Pace Coach" FontSize="27" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DeviceName}" Margin="0,4,0,0" Foreground="{DynamicResource SecondaryText}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hide" Command="{Binding HideCommand}" Style="{StaticResource QuietButtonStyle}" />
                    <Button Content="Exit" Command="{Binding ExitCommand}" Style="{StaticResource QuietButtonStyle}" Margin="0" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    Padding="18"
                    CornerRadius="28"
                    Background="{Binding AlertBackgroundBrush}"
                    BorderBrush="{Binding AlertBorderBrush}"
                    BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="{Binding AlertBadgeBrush}" CornerRadius="999" Padding="12,5">
                            <TextBlock Text="{Binding AlertHeadline}" FontSize="13" FontWeight="SemiBold" Foreground="#08111F" />
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="12,3,0,0"
                                   Foreground="#E2E8F0"
                                   TextWrapping="Wrap"
                                   Width="238" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Text="{Binding CurrentWpm, StringFormat={}{0:N0}}" FontSize="66" FontWeight="Bold" />
                        <TextBlock Text="Estimated WPM" Margin="0,-8,0,0" FontSize="14" Foreground="{DynamicResource SubtleText}" />
                    </StackPanel>

                    <ProgressBar Grid.Row="2"
                                 Margin="0,14,0,0"
                                 Height="10"
                                 Maximum="220"
                                 Value="{Binding CurrentWpm, Mode=OneWay}"
                                 Background="{DynamicResource ProgressTrack}"
                                 Foreground="{Binding AlertBorderBrush}" />

                    <TextBlock Grid.Row="3"
                               Margin="0,14,0,0"
                               Text="{Binding PaceNarrative}"
                               Foreground="{DynamicResource NarrativeText}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCardStyle}" Background="{Binding StatCardBackgroundBrush}">
                    <StackPanel>
                        <TextBlock Text="📈 15s average" Foreground="{DynamicResource SecondaryText}" FontSize="12" />
                        <TextBlock Text="{Binding RollingWpm, StringFormat={}{0:N0}}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="{Binding RollingWpmForeground}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCardStyle}" Background="{Binding StatCardBackgroundBrush}" Margin="10,0,0,10">
                    <StackPanel>
                        <TextBlock Text="📉 Trend" Foreground="{DynamicResource SecondaryText}" FontSize="12" />
                        <TextBlock Text="{Binding TrendLabel}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{Binding TrendForeground}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCardStyle}" Background="{Binding StatCardBackgroundBrush}">
                    <StackPanel>
                        <TextBlock Text="⏱ Session time" Foreground="{DynamicResource SecondaryText}" FontSize="12" />
                        <TextBlock Text="{Binding SessionElapsedLabel}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCardStyle}" Background="{Binding StatCardBackgroundBrush}" Margin="10,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🔥 Time in zone" Foreground="{DynamicResource SecondaryText}" FontSize="12" />
                        <TextBlock Text="{Binding TimeInZoneLabel}" Margin="0,8,0,0" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource StatCardStyle}" Background="{Binding StatCardBackgroundBrush}">
                    <StackPanel>
                        <TextBlock Text="🎯 Confidence" Foreground="{DynamicResource SecondaryText}" FontSize="12" />
                        <TextBlock Text="{Binding ConfidenceLabel}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="{Binding ConfidenceForeground}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource StatCardStyle}" Background="{Binding StatCardBackgroundBrush}" Margin="10,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🗣 Talk ratio" Foreground="{DynamicResource SecondaryText}" FontSize="12" />
                        <TextBlock Text="{Binding SpeechRatioPercent, StringFormat={}{0:N0}%}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="{Binding TalkRatioForeground}" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding MonitoringButtonLabel}" Command="{Binding StartMonitoringCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="180" />
                    <Button Content="⏹  Stop" Command="{Binding StopMonitoringCommand}" Style="{StaticResource QuietButtonStyle}" Width="100" />
                </StackPanel>

                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource SecondaryText}" Text="{Binding ThresholdSummary}" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop}" Foreground="{DynamicResource QuietButtonFg}" VerticalAlignment="Center" />
                    <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="18,0,0,0" Foreground="{DynamicResource QuietButtonFg}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Theme" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              Margin="10,0,0,0"
                              Width="120"
                              Foreground="{DynamicResource AppForeground}"
                              Background="{DynamicResource CardBackground}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox Content="Record accuracy log" IsChecked="{Binding IsRecordingAccuracy}" Foreground="{DynamicResource QuietButtonFg}" VerticalAlignment="Center" />
                    <Button Content="Open log folder"
                            Command="{Binding OpenAccuracyLogCommand}"
                            Style="{StaticResource QuietButtonStyle}"
                            Margin="18,0,0,0"
                            Padding="10,6"
                            FontSize="12" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="4"
                    Margin="0,18,0,0"
                    Padding="14"
                    CornerRadius="18"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="Troubleshooting" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Copy log"
                                    Command="{Binding CopyDiagnosticsCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    Width="86" />
                            <Button Content="Open log"
                                    Command="{Binding OpenDiagnosticsCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    Width="86"
                                    Margin="0" />
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryText}"
                               Text="{Binding LaunchModeLabel}" />

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Height="150"
                            CornerRadius="12"
                            Background="{DynamicResource ScrollBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DiagnosticMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="10,6,10,0"
                                                   Foreground="{DynamicResource SubtleText}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Recent sessions" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock DockPanel.Dock="Right" Text="{Binding SessionCountLabel}" Foreground="{DynamicResource SecondaryText}" Margin="12,3,0,0" />
                </DockPanel>

                <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RecentSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        Margin="0,0,0,10"
                                        CornerRadius="18"
                                        Background="{DynamicResource SessionItemBg}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Headline}" FontWeight="SemiBold" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding DurationLabel}" Foreground="{DynamicResource SecondaryText}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0" Text="{Binding Summary}" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Detail}" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
