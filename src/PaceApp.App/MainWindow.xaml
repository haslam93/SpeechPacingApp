<Window x:Class="PaceApp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="392"
        Height="860"
        MinWidth="360"
        MinHeight="700"
        Background="#09111F"
        Foreground="#F8FAFC"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#0F766E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#101B2D" />
            <Setter Property="BorderBrush" Value="#22324A" />
            <Setter Property="Foreground" Value="#DCE6F4" />
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>
    </Window.Resources>

    <Border Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Pace Coach" FontSize="27" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DeviceName}" Margin="0,4,0,0" Foreground="#8CA3BF" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hide" Command="{Binding HideCommand}" Style="{StaticResource QuietButtonStyle}" />
                    <Button Content="Exit" Command="{Binding ExitCommand}" Style="{StaticResource QuietButtonStyle}" Margin="0" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    Padding="18"
                    CornerRadius="28"
                    Background="{Binding AlertBackgroundBrush}"
                    BorderBrush="{Binding AlertBorderBrush}"
                    BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Background="{Binding AlertBadgeBrush}" CornerRadius="999" Padding="12,5">
                            <TextBlock Text="{Binding AlertHeadline}" FontSize="13" FontWeight="SemiBold" Foreground="#08111F" />
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="12,3,0,0"
                                   Foreground="#E2E8F0"
                                   TextWrapping="Wrap"
                                   Width="238" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Text="{Binding CurrentWpm, StringFormat={}{0:N0}}" FontSize="66" FontWeight="Bold" />
                        <TextBlock Text="Estimated WPM" Margin="0,-8,0,0" FontSize="14" Foreground="#CBD5E1" />
                    </StackPanel>

                    <ProgressBar Grid.Row="2"
                                 Margin="0,14,0,0"
                                 Height="10"
                                 Maximum="220"
                                 Value="{Binding CurrentWpm, Mode=OneWay}"
                                 Background="#172235"
                                 Foreground="{Binding AlertBorderBrush}" />

                    <TextBlock Grid.Row="3"
                               Margin="0,14,0,0"
                               Text="{Binding PaceNarrative}"
                               Foreground="#DBEAFE"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="30s average" Foreground="#8CA3BF" FontSize="12" />
                        <TextBlock Text="{Binding RollingWpm, StringFormat={}{0:N0}}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="10,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Trend" Foreground="#8CA3BF" FontSize="12" />
                        <TextBlock Text="{Binding TrendLabel}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Pause rate" Foreground="#8CA3BF" FontSize="12" />
                        <TextBlock Text="{Binding PauseRatePerMinute, StringFormat={}{0:N1}/min}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="10,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Average pause" Foreground="#8CA3BF" FontSize="12" />
                        <TextBlock Text="{Binding AveragePauseMilliseconds, StringFormat={}{0:N0} ms}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Clarity proxy" Foreground="#8CA3BF" FontSize="12" />
                        <TextBlock Text="{Binding ClarityScore, StringFormat={}{0:N0}}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource StatCardStyle}" Margin="10,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Talk ratio" Foreground="#8CA3BF" FontSize="12" />
                        <TextBlock Text="{Binding SpeechRatioPercent, StringFormat={}{0:N0}%}" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Start monitoring" Command="{Binding StartMonitoringCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="164" />
                    <Button Content="Stop" Command="{Binding StopMonitoringCommand}" Style="{StaticResource QuietButtonStyle}" Width="100" />
                </StackPanel>

                <TextBlock Margin="0,10,0,0" Foreground="#8CA3BF" Text="{Binding ThresholdSummary}" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop}" Foreground="#DCE6F4" VerticalAlignment="Center" />
                    <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="18,0,0,0" Foreground="#DCE6F4" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="4"
                    Margin="0,18,0,0"
                    Padding="14"
                    CornerRadius="18"
                    Background="#0F172A"
                    BorderBrush="#243247"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="Troubleshooting" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Copy log"
                                    Command="{Binding CopyDiagnosticsCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    Width="86" />
                            <Button Content="Open log"
                                    Command="{Binding OpenDiagnosticsCommand}"
                                    Style="{StaticResource QuietButtonStyle}"
                                    Width="86"
                                    Margin="0" />
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Foreground="#8CA3BF"
                               Text="{Binding LaunchModeLabel}" />

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Height="150"
                            CornerRadius="12"
                            Background="#09111F"
                            BorderBrush="#1E293B"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DiagnosticMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="10,6,10,0"
                                                   Foreground="#CBD5E1"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Recent sessions" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock DockPanel.Dock="Right" Text="{Binding SessionCountLabel}" Foreground="#8CA3BF" Margin="12,3,0,0" />
                </DockPanel>

                <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RecentSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        Margin="0,0,0,10"
                                        CornerRadius="18"
                                        Background="#101827"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Headline}" FontWeight="SemiBold" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding DurationLabel}" Foreground="#8CA3BF" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0" Text="{Binding Summary}" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Detail}" Foreground="#8CA3BF" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
